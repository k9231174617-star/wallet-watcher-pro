{
  "name": "wallet-watcher-pro",
  "version": "1.0.0",
  "description": "Мультичейн дашборд мониторинга кошельков в неоновом киберпанк стиле",
  "main": "js/app.js",
  "scripts": {
    "cap:init": "cap init",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync android",
    "cap:open:android": "cap open android",
    "cap:build:android": "cd android && ./gradlew assembleDebug",
    "cap:build:android:release": "cd android && ./gradlew assembleRelease",
    "cap:copy": "cap copy android",
    "android:build": "npm run cap:sync && npm run cap:build:android",
    "android:build:release": "npm run cap:sync && npm run cap:build:android:release"
  },
  "keywords": [
    "wallet",
    "crypto",
    "blockchain",
    "solana",
    "ethereum",
    "bsc",
    "base",
    "ton",
    "pwa",
    "capacitor"
  ],
  "author": "Wallet Watcher Pro",
  "license": "MIT",
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/background-runner": "^2.3.1",
    "@capacitor/clipboard": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/device": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/local-notifications": "^6.0.0",
    "@capacitor/network": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@capacitor/browser": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^6.0.0",
    "typescript": "^5.0.0"
  }
}
